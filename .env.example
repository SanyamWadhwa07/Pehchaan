# Supabase (mobile app — anon key only; safe to bundle via react-native-config)
# Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Service role: use Supabase Dashboard / CLI secrets for edge functions — NOT in this file (never ship in the app).

# Integration layer — leave empty until NHAI DataLink 3.0 credentials are provided
INTEGRATION_API_KEY=
INTEGRATION_ENDPOINT=
